# Copy to .env and adjust. All vars are prefixed LOTUS_ (see app/core/config.py).

LOTUS_ENV=development
LOTUS_DEBUG=false

LOTUS_HOST=0.0.0.0
LOTUS_PORT=5000

LOTUS_POLL_INTERVAL=15
LOTUS_MAX_POLL_INTERVAL=60
LOTUS_FIRST_FETCH_TIMEOUT=60

LOTUS_PERSIST_QUEUE_MAXSIZE=10
LOTUS_DEFAULT_FUND=lotus

# SQLAlchemy async URLs (aiosqlite driver). 3 slashes = relative path,
# 4 slashes = absolute path. Use absolute paths in any deployment where
# the process's working directory isn't guaranteed (systemd, Docker, etc).
LOTUS_LOTUS_DB_URL=sqlite+aiosqlite:///lotus_options.db
LOTUS_PORTFOLIO_DB_URL=sqlite+aiosqlite:///lotus_portfolio.db
LOTUS_SHARED_DB_URL=sqlite+aiosqlite:///app_shared.db
LOTUS_DB_ECHO=false

# Crypto domain
LOTUS_CRYPTO_TRACKED_SYMBOLS=["USDT-USD"]
LOTUS_CRYPTO_POLL_INTERVAL=30
LOTUS_CRYPTO_CACHE_TTL=10
LOTUS_CRYPTO_HTTP_TIMEOUT=10
LOTUS_CRYPTO_MIN_CALL_INTERVAL=1
LOTUS_CRYPTO_BINANCE_BASE_URL=https://api.binance.com
LOTUS_CRYPTO_COINBASE_BASE_URL=https://api.exchange.coinbase.com
LOTUS_CRYPTO_KRAKEN_BASE_URL=https://api.kraken.com
# Verify these pair mappings against each exchange's live docs — see
# app/domains/crypto/clients/*.py docstrings. Binance intentionally ships
# unmapped by default; see the comment in app/core/config.py for why.
LOTUS_CRYPTO_BINANCE_SYMBOL_MAP={}
LOTUS_CRYPTO_COINBASE_SYMBOL_MAP={"USDT-USD": "USDT-USD"}
LOTUS_CRYPTO_KRAKEN_SYMBOL_MAP={"USDT-USD": "USDTZUSD"}

# Users / Auth domain
# OTP codes are stored in Redis, not SQLite — leave unset for local dev
# (falls back to an in-memory store; see app/domains/users/otp_store.py
# for why that's dev-only). MUST be set in any real deployment.
LOTUS_REDIS_URL=redis://localhost:6379/0
# MUST override both secrets below in any non-dev environment.
LOTUS_JWT_SECRET_KEY=CHANGE_ME_dev_only_insecure_secret
LOTUS_JWT_ALGORITHM=HS256
LOTUS_ACCESS_TOKEN_EXPIRE_MINUTES=30
LOTUS_REFRESH_TOKEN_EXPIRE_DAYS=30
LOTUS_OTP_CODE_LENGTH=6
LOTUS_OTP_EXPIRE_SECONDS=300
LOTUS_OTP_RESEND_INTERVAL_SECONDS=60
LOTUS_OTP_MAX_VERIFY_ATTEMPTS=5
LOTUS_OTP_HASH_SECRET=CHANGE_ME_dev_only_otp_pepper
# Phone numbers (E.164, e.g. "+989121234567") auto-promoted to admin on
# first login — see app/domains/users/service.py::verify_otp. Leave empty
# to promote your first admin manually instead.
LOTUS_BOOTSTRAP_ADMIN_PHONE_NUMBERS=["+989121234567"]
LOTUS_AVATAR_UPLOAD_DIR=uploads/avatars
LOTUS_AVATAR_MAX_SIZE_BYTES=2097152
LOTUS_AVATAR_ALLOWED_CONTENT_TYPES=["image/jpeg", "image/png", "image/webp"]

# Commodities domain — TSETMC gold ETF tracking
LOTUS_COMMODITY_GROUPS=["gold"]
LOTUS_COMMODITY_POLL_INTERVAL=60
LOTUS_COMMODITY_CACHE_TTL=20
LOTUS_COMMODITY_HTTP_TIMEOUT=10
LOTUS_COMMODITY_MAX_CONCURRENT_REQUESTS=8

# Commodities domain — gold retail-price platforms (hamrahgold/digikala/
# technogold/talasea/milligold/melligold). See
# app/domains/commodities/clients/platform_base.py: response field names
# for all six are UNVERIFIED — every platform blocks automated fetching
# and none publish public API docs. Verify against real responses before
# trusting these values.
LOTUS_GOLD_PLATFORM_POLL_INTERVAL=60
LOTUS_GOLD_PLATFORM_CACHE_TTL=90
LOTUS_GOLD_PLATFORM_HTTP_TIMEOUT=10
LOTUS_MELLIGOLD_SYMBOL=XAU18

# Comma-separated is NOT supported directly by pydantic-settings for List[str]
# via env vars unless you set it as a JSON array string, e.g.:
LOTUS_CORS_ORIGINS=["https://your-frontend.example.com"]
LOTUS_CORS_ALLOW_CREDENTIALS=false

LOTUS_LOG_LEVEL=INFO

LOTUS_STATIC_DIR=static
LOTUS_INDEX_FILE=index1.html
